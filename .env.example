# Example environment variables
# Copy this file to .env and fill in your actual values

# Gateway Configuration
GATEWAY_URL=http://localhost:8000
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000

# MCP Server Configuration
MCP_URL=http://localhost:9000
MCP_HOST=0.0.0.0
MCP_PORT=9000

# Shopify App Configuration
SHOPIFY_APP_URL=http://localhost:3000
SHOPIFY_APP_PORT=3000
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret

# WooCommerce Configuration
WOOCOMMERCE_GATEWAY_URL=http://localhost:8000
WOOCOMMERCE_API_KEY=your_woocommerce_api_key
WOOCOMMERCE_API_SECRET=your_woocommerce_api_secret

# Python Configuration
PYTHONUNBUFFERED=1

# Database (for production)
DATABASE_URL=postgresql://user:password@localhost:5432/agentic_commerce

# Logging
LOG_LEVEL=INFO
